{
    "builds":[
        {
            "src": "run.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "run.py"
        }
    ],
    "redirects": [
        {
            "source": "https://www.iscore.vercel.app/:path*",
            "destination": "https://iscore.vercel.app/:path*",
            "permanent": true
        }
    ]
}